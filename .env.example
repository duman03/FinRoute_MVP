NODE_ENV=development
PORT=3001
POSTGRES_USER=finroute
POSTGRES_PASSWORD=REPLACE_WITH_LOCAL_POSTGRES_PASSWORD
POSTGRES_DB=finroute_db
DATABASE_URL=postgresql://finroute:REPLACE_WITH_LOCAL_POSTGRES_PASSWORD@localhost:5432/finroute_db
